    "settings.general.language_help": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认跟随系统语言。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uses your system language by default."
          }
        }
      }
