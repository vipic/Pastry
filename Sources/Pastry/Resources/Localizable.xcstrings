    "settings.delete_requires_confirmation.help": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后键盘、工具栏与右键删除前会弹出确认。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, ask before deleting from keyboard, toolbar, or context menu."
          }
        }
      }
