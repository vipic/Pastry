    "settings.security.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制 Pastry 可访问的内容、需要忽略的应用，以及链接预览是否可以联网。"
          }
