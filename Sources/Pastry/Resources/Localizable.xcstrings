    },
    "settings.card_click_mode.help": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后单击粘贴；关闭后单击选中，再点已选卡片粘贴。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, click pastes; when off, click selects and click again pastes."
          }
        }
      }
    },
    "settings.delete_requires_confirmation": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
