    "help.usage.capture_desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pastry 自动监听系统剪贴板。复制任何内容 — 文本、图片、文件、链接、HTML — 都会出现在面板中。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pastry automatically monitors your clipboard. Copy anything — text, images, files, links, HTML — and it appears in the panel."
          }
        }
      }
    },
    "help.usage.paste_desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "单击卡片直接粘贴到当前应用。双击或按 ⏎ 同理。按住 ⌘ 可在卡片右下角看到数字角标，按 ⌘+数字 快速粘贴。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a card to paste directly into the active app. Double-click or press ⏎ also works. Hold ⌘ to see number badges on cards, then press ⌘+number for quick paste."
          }
        }
      }
    },
    "help.usage.manage_desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "右键卡片可收藏（favorite）、预览、分享、删除。收藏的条目在「已收藏」标签页中始终可见，不受历史清理影响。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Right-click cards to favorite, preview, share, or delete. Favorited items remain visible in the Favorites tab, unaffected by history clearing."
          }
        }
      }
    },
    "help.usage.filter_desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "搜索框支持实时过滤。筛选按钮可按类型（文本/链接/图片等）、来源应用、时间范围筛选，多个条件可叠加。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The search bar supports real-time filtering. Filter buttons let you filter by type (text/link/image, etc.), source app, and time range. Multiple conditions can be combined."
          }
        }
      }
    },
    "help.tip.drag_save": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖拽卡片到桌面或 Finder 可直接保存文件"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag cards to Desktop or Finder to save files directly"
          }
        }
      }
    },
