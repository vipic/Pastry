    "about.description": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "轻灵的剪贴板伴侣。自动记录文字、图片、文件与链接，全局唤起、即搜即用，让每一次复制都不再转瞬即逝。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A lightweight clipboard companion. Automatically saves text, images, files, and links. Summon it globally, search instantly — your clipboard, remembered."
          }
        }
      }
    },
