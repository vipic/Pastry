    "settings.general.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整日常行为：语言、启动、提示音、左键点击操作、删除确认、历史保留和数据清理。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tune the everyday behavior: language, launch, sounds, left-click action, delete confirmation, history retention, and data cleanup."
          }
        }
      }
    },
    "settings.sidebar.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剪贴板设置"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard settings"
          }
        }
      }
    },
    "settings.sidebar.footer": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地优先的剪贴板历史。远程预览默认保持关闭。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local-first clipboard history. Network previews stay off until enabled."
          }
        }
      }
    },
