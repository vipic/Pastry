    "settings.general.launch_help": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录 macOS 时静默启动 Pastry。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Pastry quietly when you log in to macOS."
          }
        }
      }
    },
    "settings.general.sound_help": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "复制和粘贴时播放提示音。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Play a sound when copying or pasting."
          }
        }
      }
    },
    "settings.card_click_mode": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "左键点击操作"
